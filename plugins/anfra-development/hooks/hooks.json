{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-aml.sh\"",
            "timeout": 30,
            "statusMessage": "Validating AML..."
          }
        ]
      }
    ]
  }
}
